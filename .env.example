# Use FBIF login app credentials
FEISHU_APP_ID=cli_fbif_xxx
FEISHU_APP_SECRET=fbif_app_secret
# OAuth login callback (must also be configured in Feishu Open Platform)
FEISHU_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/feishu/callback
FEISHU_OAUTH_SCOPE=contact:user.base:readonly drive:drive drive:file docx:document:readonly wiki:wiki
# Comma-separated allowlist of Feishu tenant_keys (FBIF + partner orgs).
# Leave empty to allow any tenant (dev only). In production, fill with the real
# tenant_key from the first successful login (printed in server logs).
FEISHU_ALLOWED_TENANT_KEYS=
SESSION_COOKIE_NAME=larkdocvar_session
SESSION_COOKIE_SECURE=false
# Recommended: 'lax' for same-site embed; use 'none' only when cross-site is required and HTTPS is enabled.
SESSION_COOKIE_SAMESITE=lax
# Session persistence upper bound for embedded webviews: 7 days inactivity
SESSION_MAX_AGE_SECONDS=604800
FRONTEND_POST_LOGIN_URL=http://localhost:5173
# PostgreSQL storage
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/larkdocvar
# One-time migration from legacy Bitable configs to PostgreSQL
BITABLE_APP_TOKEN=your_legacy_bitable_app_token
BITABLE_TABLE_ID=your_legacy_bitable_table_id
# Local API port in dev mode
PORT=3000
HOST=0.0.0.0
# Docker only: host machine mapped port
HOST_PORT=18081
# Docker only: container internal app port
CONTAINER_PORT=3180
