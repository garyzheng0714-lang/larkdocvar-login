# Use FBIF login app credentials
FEISHU_APP_ID=cli_fbif_xxx
FEISHU_APP_SECRET=fbif_app_secret
# OAuth login callback (must also be configured in Feishu Open Platform)
FEISHU_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/feishu/callback
FEISHU_OAUTH_SCOPE=contact:user.base:readonly drive:drive drive:file docx:document:readonly wiki:wiki
# Comma-separated allowlist of Feishu tenant_keys (FBIF + partner orgs).
# Empty is accepted only outside production. Production must fill this.
FEISHU_ALLOWED_TENANT_KEYS=
# Comma-separated suffix allowlist for server-side image downloads.
# Keep defaults unless Feishu attachment URLs use an additional trusted domain.
FEISHU_IMAGE_DOWNLOAD_ALLOWED_HOSTS=
SESSION_COOKIE_NAME=larkdocvar_session
SESSION_COOKIE_SECURE=false
# Recommended: 'lax' for same-site embed; use 'none' only when cross-site is required and HTTPS is enabled.
SESSION_COOKIE_SAMESITE=lax
# Session persistence upper bound for embedded webviews: 7 days inactivity
SESSION_MAX_AGE_SECONDS=604800
FRONTEND_POST_LOGIN_URL=http://localhost:5173
# PostgreSQL storage
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/larkdocvar
# One-time migration from legacy Bitable configs to PostgreSQL
BITABLE_APP_TOKEN=your_legacy_bitable_app_token
BITABLE_TABLE_ID=your_legacy_bitable_table_id
# Local API port in dev mode
PORT=3000
HOST=0.0.0.0
# Document render API local fallback storage. Leave empty to use the system temp directory.
DOCUMENT_RENDER_STORAGE_DIR=
# Local experiments may use localhost template links. Keep false/empty in production.
DOCUMENT_TEMPLATE_ALLOW_PRIVATE_URLS=
# Optional public base URL for download links, e.g. https://api.example.com. Empty returns relative paths.
DOCUMENT_RENDER_PUBLIC_BASE_URL=
# Optional API key for server-to-server Docx APIs. When set, callers must send Authorization: Bearer ... or x-api-key.
DOCUMENT_RENDER_API_KEY=
# Comma-separated Feishu open_id list. Admins can modify/delete any Docx template.
DOCUMENT_TEMPLATE_ADMIN_OPEN_IDS=
# OSS output storage. When all four values are present, generated Docx files are uploaded to OSS.
# Region accepts cn-beijing or oss-cn-beijing.
DOCUMENT_RENDER_STORAGE_PROVIDER=
DOCUMENT_RENDER_OSS_ACCESS_KEY_ID=
DOCUMENT_RENDER_OSS_ACCESS_KEY_SECRET=
DOCUMENT_RENDER_OSS_BUCKET=
DOCUMENT_RENDER_OSS_REGION=
DOCUMENT_RENDER_OSS_PREFIX=document-renders
# Optional TOS output storage. Set DOCUMENT_RENDER_STORAGE_PROVIDER=tos when both OSS and TOS are present.
TOS_ACCESS_KEY=
TOS_SECRET_KEY=
TOS_BUCKET=
TOS_REGION=
TOS_ENDPOINT=
DOCUMENT_RENDER_TOS_PREFIX=document-renders
# Docx template asset storage. Production must use TOS; local fallback is development only.
DOCUMENT_TEMPLATE_STORAGE_PROVIDER=
DOCUMENT_TEMPLATE_TOS_PREFIX=document-templates
DOCUMENT_TEMPLATE_STORAGE_DIR=
# Download link TTL. Prefer seconds for OSS signed URLs; the ms setting is kept for local fallback compatibility.
DOCUMENT_RENDER_DOWNLOAD_TTL_SECONDS=3600
DOCUMENT_RENDER_DOWNLOAD_TTL_MS=3600000
DOCUMENT_RENDER_MAX_FILES=100
# In-memory async render job retention. Completed/failed jobs are removed after TTL or when max count is exceeded.
DOCUMENT_RENDER_JOB_TTL_SECONDS=86400
DOCUMENT_RENDER_MAX_JOBS=100
# Docx safety limits.
DOCUMENT_RENDER_MAX_UNZIPPED_BYTES=104857600
DOCUMENT_RENDER_MAX_ZIP_ENTRIES=1000
# Optional Feishu import verification. Dry-run by default; set true only when you want to create a cloud doc.
# User authorization is managed by lark-cli auth, not by a token in this .env file.
# Before execute mode, verify: lark-cli auth status --verify && lark-cli auth check --scope docs:document:import
DOCUMENT_RENDER_FEISHU_IMPORT_EXECUTE=false
DOCUMENT_RENDER_FEISHU_IMPORT_FOLDER_TOKEN=
DOCUMENT_RENDER_FEISHU_IMPORT_AS=user
# Optional desktop client verification. auto tries Word first, then WPS.
DOCUMENT_RENDER_CLIENT_APP=auto
DOCUMENT_RENDER_CLIENT_WORD_APP=/Applications/Microsoft Word.app
DOCUMENT_RENDER_CLIENT_WPS_APP=/Applications/wpsoffice.app
# Optional verifier output paths.
DOCUMENT_RENDER_OSS_REPORT_PATH=
DOCUMENT_RENDER_VERIFY_OUTPUT_PATH=
DOCUMENT_RENDER_VERIFY_REPORT_PATH=
DOCUMENT_RENDER_CLIENT_REPORT_PATH=
DOCUMENT_RENDER_FEISHU_IMPORT_REPORT_PATH=
# Docker only: compose/container names and mapped ports
APP_NAME=fbif-sidebar-docgen
POSTGRES_CONTAINER_NAME=fbif-sidebar-docgen-postgres
POSTGRES_HOST_PORT=15433
HOST_PORT=19094
# Docker only: container internal app port
CONTAINER_PORT=3180
