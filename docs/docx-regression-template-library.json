{
  "description": "Docx API milestone 1 regression template library. Each entry must be covered by server/src/documentRenderApi.test.ts.",
  "templates": [
    { "name": "合同-基础段落", "category": "contract", "covers": ["body", "multi-variable"], "expectedVariables": ["客户名称", "金额"] },
