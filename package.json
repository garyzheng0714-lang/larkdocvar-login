{
  "name": "feishu-sidebar-docx-template-filler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bash scripts/dev-up.sh",
    "dev:raw": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:web": "vite",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && npm run build:web",
    "build:web": "vite build",
    "test": "DOCUMENT_RENDER_SKIP_PROJECT_ENV=true node --import tsx --test \"server/src/**/*.test.ts\" \"src/**/*.test.ts\" \"src/**/*.test.tsx\"",
    "verify:oss": "node --import tsx server/src/scripts/verifyOssStorage.ts",
    "verify:document-render": "node --import tsx server/src/scripts/verifyDocumentRenderMilestone1.ts",
    "verify:docx-client": "node --import tsx server/src/scripts/verifyDocxClientOpen.ts",
    "verify:feishu-import": "node --import tsx server/src/scripts/verifyFeishuDocxImport.ts",
    "verify:document-render-milestone1": "node --import tsx server/src/scripts/verifyDocumentRenderMilestone1Full.ts",
    "verify:secrets": "node --import tsx server/src/scripts/verifyNoTrackedSecrets.ts",
    "audit:document-render-milestone1": "node --import tsx server/src/scripts/auditDocumentRenderMilestone1.ts",
    "configure:oss-local": "node --import tsx server/src/scripts/configureDocumentRenderOssLocal.ts",
    "preview": "vite preview",
    "start": "node --import tsx server/src/index.ts",
    "start:prod": "NODE_ENV=production node --import tsx server/src/index.ts",
    "migrate:bitable-to-pg": "node --import tsx server/src/scripts/migrateBitableToPostgres.ts",
    "backup:postgres": "bash scripts/backup-postgres.sh",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f fbif-sidebar-docgen"
  },
  "dependencies": {
    "@lark-base-open/js-sdk": "^1.0.2",
    "ali-oss": "^6.23.0",
    "axios": "^1.16.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "easy-template-x": "^7.2.4",
    "express": "^5.2.1",
    "form-data": "^4.0.5",
    "jszip": "^3.10.1",
    "lucide-react": "^0.575.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@types/ali-oss": "^6.23.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
